# ── DATABASE ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@host:5432/mspmo?sslmode=require"

# ── REDIS ─────────────────────────────────────────────────────────────────────
REDIS_URL="redis://default:password@host:6379"

# ── AUTH (Clerk) ──────────────────────────────────────────────────────────────
CLERK_SECRET_KEY="sk_live_..."
CLERK_WEBHOOK_SECRET="whsec_..."
# Frontend
VITE_CLERK_PUBLISHABLE_KEY="pk_live_..."

# ── AI (Anthropic) ────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY="sk-ant-..."

# ── BILLING (Stripe) ──────────────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_STARTER_PRICE_ID="price_..."
STRIPE_GROWTH_PRICE_ID="price_..."
STRIPE_ENTERPRISE_PRICE_ID="price_..."

# ── FILE STORAGE (S3-compatible) ──────────────────────────────────────────────
S3_BUCKET="mspmo-uploads"
S3_REGION="us-east-1"
S3_ACCESS_KEY_ID="..."
S3_SECRET_ACCESS_KEY="..."
S3_ENDPOINT=""  # Leave blank for AWS, set for Cloudflare R2 / Backblaze

# ── APP ───────────────────────────────────────────────────────────────────────
NODE_ENV="development"
API_PORT="3001"
API_URL="http://localhost:3001"
WEB_URL="http://localhost:5173"
ENCRYPTION_KEY="32-byte-hex-string-for-aes-256"

# ── CONNECTWISE (per-tenant, stored encrypted in DB — these are for local dev) ─
CW_DEV_COMPANY_ID=""
CW_DEV_PUBLIC_KEY=""
CW_DEV_PRIVATE_KEY=""
CW_DEV_CLIENT_ID=""
CW_DEV_SITE="na.myconnectwise.net"
